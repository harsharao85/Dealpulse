# DealPulse — Environment Variables
# Copy this file to .env and fill in your values.

# Anthropic API Key (local development)
# In production on SAP BTP: remove this and use SAP AI Core Generative AI Hub
# bound via VCAP_SERVICES (XSUAA). Replace the Anthropic client in
# srv/dealpulse-service.js with @sap-ai-sdk/foundation-models.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Server port (optional, defaults to 3001)
PORT=3001
